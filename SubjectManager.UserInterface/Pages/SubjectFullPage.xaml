<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:SubjectManager.UserInterface.ViewModels"
    xmlns:view="clr-namespace:SubjectManager.Model.View"
    xmlns:view1="using:SubjectManager.Model.View"
    x:Class="SubjectManager.UserInterface.Pages.SubjectFullPage"
    x:DataType="viewModels:SubjectFullViewModel"
    Title="Subject Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="{Binding Subject.Name, FallbackValue=''}" FontSize="20"/>
            <Label Text="{Binding Subject.Credits, StringFormat='Credits: {0}', FallbackValue=''}"/>
            <Label Text="{Binding Subject.FieldOfKnowledge, Converter={StaticResource CamelCaseConverter}, StringFormat='Field: {0}', FallbackValue=''}"/>
            <Label Text="{Binding Subject.DurationTotal, StringFormat='Total Duration: {0}', FallbackValue=''}"/>

            <Label Text="Lessons:" FontAttributes="Bold" Margin="0,20,0,0"/>

            <HorizontalStackLayout Spacing="10">
                <Button Text="Add Lesson" Command="{Binding AddLessonCommand}" />
                <!-- <Button Text="Edit Lesson" Command="{Binding EditLessonCommand}" /> -->
                <!-- <Button Text="Delete Lesson" Command="{Binding DeleteLessonCommand}" /> -->
            </HorizontalStackLayout>
            <Label Text="Filters" FontAttributes="Bold" Margin="0,10,0,0"/>

            <HorizontalStackLayout Spacing="10">
                <Picker Title="Lesson Type"
                        ItemsSource="{Binding LessonTypes}"
                        SelectedItem="{Binding SelectedLessonType}" />

                <DatePicker Date="{Binding BeginDateFrom}" />
                <DatePicker Date="{Binding BeginDateTo}" />

                <Button Text="Clear Filters" Command="{Binding ClearFiltersCommand}" />
            </HorizontalStackLayout>
            
            <CollectionView
                ItemsSource="{Binding Lessons}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedLesson}"
                SelectionChangedCommand="{Binding LessonSelectedCommand}">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="view1:LessonListItem">
                        <Frame Padding="20" Margin="10" BackgroundColor="{StaticResource ItemList}">
                            <VerticalStackLayout>
                                <Label Text="{Binding BeginDate}" />
                                <Label Text="{Binding LessonType}" />
                                
                                <HorizontalStackLayout Spacing="10">
                                    <Button
                                        Text="Edit"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SubjectFullViewModel}}, Path=EditLessonCommand}"
                                        CommandParameter="{Binding .}" />

                                    <Button
                                        Text="Delete"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SubjectFullViewModel}}, Path=DeleteLessonCommand}"
                                        CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <Button
                Text="Back to Subjects"
                Command="{Binding BackCommand}"
                Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>