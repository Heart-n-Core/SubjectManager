<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:SubjectManager.UserInterface.ViewModels"
    xmlns:view="clr-namespace:SubjectManager.Model.View"
    xmlns:view1="using:SubjectManager.Model.View"
    x:Class="SubjectManager.UserInterface.Pages.SubjectFullPage"
    x:DataType="viewModels:SubjectFullViewModel"
    Title="Subject Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label Text="{Binding Subject.Name, FallbackValue=''}" FontSize="20"/>
            <Label Text="{Binding Subject.Credits, StringFormat='Credits: {0}', FallbackValue=''}"/>
            <Label Text="{Binding Subject.FieldOfKnowledge, Converter={StaticResource CamelCaseConverter}, StringFormat='Field: {0}', FallbackValue=''}"/>
            <Label Text="{Binding Subject.DurationTotal, StringFormat='Total Duration: {0}', FallbackValue=''}"/>

            <Label Text="Lessons:" FontAttributes="Bold" Margin="0,20,0,0"/>

            <CollectionView
                ItemsSource="{Binding Lessons}"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedLesson}"
                SelectionChangedCommand="{Binding LessonSelectedCommand}">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="view1:LessonListItem">
                        <Frame Padding="20" Margin="10" BackgroundColor="{StaticResource ItemList}">
                            <VerticalStackLayout>
                                <Label Text="{Binding BeginDate}" />
                                <Label Text="{Binding LessonType}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <Button
                Text="Back to Subjects"
                Command="{Binding BackCommand}"
                Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>