<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:SubjectManager.UserInterface.ViewModels"
             xmlns:view="using:SubjectManager.Model.View"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewModels:MainPageViewModel"
             x:Class="SubjectManager.UserInterface.Pages.MainPage"
             Title="Subjects">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadSubjectsCommand}" />
    </ContentPage.Behaviors>
    
<ScrollView>
    <VerticalStackLayout Padding="20" Spacing="10">

        <!-- Add / Search / Filter -->
        <Button Text="Add Subject" Command="{Binding AddSubjectCommand}" Margin="10"/>

        <SearchBar Placeholder="Search by name"
                   Text="{Binding SearchText, Mode=TwoWay}"
                   SearchCommand="{Binding ApplyFiltersCommand}" />

        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
            <Picker Title="Filter by Field"
                    ItemsSource="{Binding Fields}"
                    SelectedItem="{Binding SelectedField, Mode=TwoWay}" />
            <Button Text="Clear Name Filter" Command="{Binding ClearSearchCommand}" />
            <Button Text="Clear Field of knowledge Filter" Command="{Binding ClearFieldFilterCommand}" />
            <Button Text="Clear All Filters" Command="{Binding ClearAllFiltersCommand}" />
        </HorizontalStackLayout>

        <CollectionView
            ItemsSource="{Binding Subjects}"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedSubject}"
            SelectionChangedCommand="{Binding SubjectSelectedCommand}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="view:SubjectListItem">
                    <Frame Padding="20" Margin="10" BackgroundColor="{StaticResource ItemList}">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding FieldOfKnowledge, Converter={StaticResource CamelCaseConverter}}" FontSize="14" />
                            
                            <HorizontalStackLayout Spacing="10">
                                <Button
                                    Text="Edit"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:MainPageViewModel}}, Path=EditSubjectCommand}"
                                    CommandParameter="{Binding .}" />

                                <Button
                                    Text="Delete"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:MainPageViewModel}}, Path=DeleteSubjectCommand}"
                                    CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ScrollView>
</ContentPage>